# =========================================================================
# STUFFY SUPERMARKET - CONFIGURATION FOR REAL PRODUCTION DOCKER / SERVICES
# =========================================================================

# Database & Token Secret
# LƯU Ý: Luồng tạo đơn hàng (POST /api/orders) dùng MongoDB multi-document
# transaction, BẮT BUỘC MongoDB chạy ở chế độ replica set. Chuỗi kết nối
# phải kèm tham số ?replicaSet=rs0. Với dev local ngoài Docker: chạy
# `mongod --replSet rs0` rồi `rs.initiate()` một lần. Trong Docker Compose,
# host là `mongodb` thay cho `localhost`.
MONGO_URI=mongodb://localhost:27017/stuffy_db?replicaSet=rs0
JWT_SECRET=your_secure_random_jwt_secret_key_here
NODE_ENV=production

# -------------------------------------------------------------------------
# 1. PORTAL THANH TOÁN THẬT - PAYOS (VietQR)
# Đăng ký tài khoản doanh nghiệp tại: https://payos.vn để lấy Key
# -------------------------------------------------------------------------
PAYOS_CLIENT_ID=your_real_payos_client_id
PAYOS_API_KEY=your_real_payos_api_key
PAYOS_CHECKSUM_KEY=your_real_payos_checksum_key

# -------------------------------------------------------------------------
# 2. VẬN CHUYỂN THẬT - LOGISTICS API (GHN, GHTK, Viettel Post)
# Điền Token thật để hệ thống tự động kết nối báo phí ship & tạo vận đơn
# -------------------------------------------------------------------------
GHN_TOKEN=your_real_ghn_token_here
GHTK_TOKEN=your_real_ghtk_token_here
VIETTELPOST_TOKEN=your_real_viettelpost_token_here

# -------------------------------------------------------------------------
# 3. TRÍ TUỆ NHÂN TẠO - GEMINI AI SEARCH (Tìm kiếm hình ảnh)
# Lấy Gemini Key tại Google AI Studio để phân tích ảnh sản phẩm
# -------------------------------------------------------------------------
GEMINI_API_KEY=your_real_gemini_api_key_here

# -------------------------------------------------------------------------
# 4. GỬI EMAIL THẬT - SMTP SERVER (Xác thực tài khoản qua Nodemailer)
# Ví dụ cấu hình qua Gmail SMTP (cần dùng mật khẩu ứng dụng App Password)
# -------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password_here
SMTP_FROM="Stuffy Supermarket" <your_email@gmail.com>
